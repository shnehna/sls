PODCAST_INDEX_KEY=your_podcastindex_key
PODCAST_INDEX_SECRET=your_podcastindex_secret

# Optional backend STT automation. Without these, local dev uses the mock provider.
STT_PROVIDER=deepgram
STT_CALLBACK_BASE_URL=https://your-pages-domain.example
STT_WEBHOOK_SECRET=your_webhook_secret
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=nova-3
