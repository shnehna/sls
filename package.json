{
  "name": "podcast-shadow-reader",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.functions.json",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && npx wrangler pages dev dist",
    "db:migrate:local": "npx wrangler d1 migrations apply shadowcast --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply shadowcast --remote"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
